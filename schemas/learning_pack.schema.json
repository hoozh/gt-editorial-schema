{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gt-editorial-schema.local/schemas/learning_pack.schema.json",
  "title": "Operational Learning Pack",
  "description": "Portable artifact produced by human editorial review that converts an approved article/block into reusable knowledge for BiBLIO, GHS, SKULL, and WRITY.",
  "type": "object",
  "additionalProperties": false,
  "required": ["pack_id", "producer", "generated_at", "article_identity", "editorial_decision", "audit"],
  "properties": {
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-_.:]+$",
      "examples": ["learning_pack::coinpoker-review::20260709-143205"]
    },
    "producer": {
      "const": "human",
      "description": "Always human review. Not part of the editorial_objects producer enum because this pack is never machine-generated."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "article_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document_slug"],
      "properties": {
        "document_slug": { "type": "string", "minLength": 1 },
        "article_topic": { "type": "string" },
        "article_type": {
          "type": "string",
          "description": "Must match taxonomy/article_types.json."
        },
        "source_spreadsheet_row": { "type": "string" }
      }
    },
    "editorial_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overall_result", "reviewed_at"],
      "properties": {
        "overall_result": {
          "type": "string",
          "enum": ["approved", "approved_with_minor_edits", "rewritten", "regenerate", "needs_review"]
        },
        "reviewer": {
          "type": "string",
          "description": "For traceability, not automated authorship attribution."
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "approved_blocks": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["block_type", "final_text", "editorial_result"],
        "properties": {
          "block_type": {
            "type": "string",
            "description": "Must match taxonomy/block_types.json."
          },
          "final_text": { "type": "string" },
          "scores": {
            "type": "object",
            "additionalProperties": false,
            "required": ["exactitud", "naturalidad", "SEO", "estilo_GT", "utilidad_general", "confianza_para_reutilizar"],
            "properties": {
              "exactitud": { "type": "integer", "minimum": 1, "maximum": 5 },
              "naturalidad": { "type": "integer", "minimum": 1, "maximum": 5 },
              "SEO": { "type": "integer", "minimum": 1, "maximum": 5 },
              "estilo_GT": { "type": "integer", "minimum": 1, "maximum": 5 },
              "utilidad_general": { "type": "integer", "minimum": 1, "maximum": 5 },
              "confianza_para_reutilizar": { "type": "integer", "minimum": 1, "maximum": 5 }
            }
          },
          "editorial_result": {
            "type": "string",
            "enum": ["approved", "approved_with_minor_edits", "rewritten", "regenerate", "needs_review"]
          },
          "can_train_future_auto_approval": {
            "type": "boolean",
            "default": false
          }
        }
      }
    },
    "extracted_knowledge": {
      "type": "object",
      "additionalProperties": false,
      "default": {},
      "properties": {
        "entities": {
          "type": "array",
          "items": { "$ref": "./entities.schema.json" },
          "default": []
        },
        "relationships": {
          "type": "array",
          "items": { "$ref": "./relationships.schema.json" },
          "default": []
        },
        "reusable_notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        }
      }
    },
    "consumption_flags": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "biblio_stable_promotion_executed": { "type": "boolean", "default": false },
        "skull_feedback_applied": { "type": "boolean", "default": false },
        "writy_reference_available": { "type": "boolean", "default": false },
        "ghs_signal_recorded": { "type": "boolean", "default": false },
        "linky_bridge_updated": { "type": "boolean", "default": false }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_type", "original_location", "extraction_date", "transformation_step", "confidence", "human_review_status"],
      "properties": {
        "source_id": { "type": "string" },
        "source_type": { "type": "string" },
        "original_location": { "type": "string" },
        "extraction_date": { "type": "string", "format": "date" },
        "transformation_step": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "stale_after": { "type": "string", "format": "date" },
        "human_review_status": {
          "type": "string",
          "enum": ["pending", "reviewed", "approved", "rejected"]
        },
        "notes": { "type": "string" }
      }
    }
  }
}
