{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gt-editorial-schema.local/schemas/relationships.schema.json",
  "title": "Editorial Relationship",
  "description": "Shared contract for lightweight relationships between editorial entities.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "from_entity_id", "to_entity_id"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-_.:]+$"
    },
    "type": {
      "type": "string",
      "description": "Must match taxonomy/relationship_types.json."
    },
    "from_entity_id": {
      "type": "string"
    },
    "to_entity_id": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "default": []
    },
    "notes": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
